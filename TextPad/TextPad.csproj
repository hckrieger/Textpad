<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>TextPad.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="TextPad.ico" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="TextPad.ico" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="TextPad.ico" />
  </ItemGroup>

</Project>
